# Copy this file to .env and fill in values before running locally.
# Never commit .env to version control.

DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DATABASE_URL=postgres://pcro:pcro@localhost:5432/pcro
ALLOWED_HOSTS=localhost,127.0.0.1
ROUTE_API_KEY=                 # shared secret for POST /api/routes/ and GET /api/routes/<id>/
SOCRATA_APP_TOKEN=            # optional; raises NYC Open Data rate limits
