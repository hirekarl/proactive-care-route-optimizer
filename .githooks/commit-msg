#!/usr/bin/env sh
# Refuse commits that attribute work to AI tools (Claude, Anthropic).
# Collaborators are expected to author their own commits.

commit_msg_file="$1"

if grep -iE 'co-authored-by:.*(claude|anthropic)' "$commit_msg_file" > /dev/null 2>&1; then
  echo ""
  echo "  ✗  Commit rejected: Co-author attribution to Claude or Anthropic is not allowed."
  echo "     Remove the Co-Authored-By line and recommit."
  echo ""
  exit 1
fi
